# =====================================================
# のまぼど LINEミニアプリ 環境変数サンプル
# このファイルを .env.local にコピーして値を設定してください
# =====================================================

# ----- LIFF -----
# LINEデベロッパーコンソール > LIFFアプリ > LIFF ID
NEXT_PUBLIC_LIFF_ID=1234567890-xxxxxxxx

# ----- LINE (サーバー側) -----
# LINEデベロッパーコンソール > チャネル基本設定
LINE_CHANNEL_ID=1234567890
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- Vercel Postgres -----
# Vercelダッシュボード > Storage > Postgres から自動的に取得
# ローカル開発時は Vercel CLI の `vercel env pull .env.local` で取得
POSTGRES_PRISMA_URL=postgresql://user:pass@host/db?pgbouncer=true&sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://user:pass@host/db?sslmode=require

# ----- Stripe -----
# Stripeダッシュボード > 開発者 > APIキー
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripeダッシュボード > Webhookのシークレット
# ローカル: stripe listen --forward-to localhost:3000/api/stripe/webhook でwhsec_が表示される
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripeダッシュボード > 商品 > 月額プランの価格ID
STRIPE_SUBSCRIPTION_PRICE_ID=price_...

# ----- App -----
# 本番: VercelのデプロイURL
# 開発: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://nomabodo.vercel.app

# 管理者Cookieの署名に使う秘密鍵（32文字以上のランダム文字列）
# 生成例: openssl rand -base64 32
ADMIN_COOKIE_SECRET=your-32-char-secret-here
